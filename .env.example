# Runtime modes
APP_DATA_MODE=supabase
# legacy stripe/mock mode kept for QA and backwards compatibility
APP_PAYMENT_MODE=auto

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional, consent-gated GA4 measurement ID. Internal KPI uses first-party funnel ledger instead.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
JITSI_BASE_URL=https://meet.jit.si
RESERVATION_WINDOW_MINUTES=15
ADMIN_ACCESS_SECRET=
TEST_CHECKOUT_ENABLED=false
QA_CHECKOUT_EMAIL_ALLOWLIST=
QA_CHECKOUT_PHONE_ALLOWLIST=

# Mail / reminders
MAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=
CUSTOMER_EMAIL_MODE=auto
GMAIL_SMTP_USER=
GMAIL_SMTP_APP_PASSWORD=
GMAIL_FROM_EMAIL=
ADMIN_NOTIFICATION_EMAIL=
BEHAVIOR15_CONTACT_EMAIL=
BEHAVIOR15_CONTACT_PHONE=
# Shared secret for the protected reminder runner endpoint triggered by Supabase scheduler
CRON_SECRET=

# Manual payment
MANUAL_PAYMENT_BLIK_PHONE=
MANUAL_PAYMENT_BANK_ACCOUNT=
MANUAL_PAYMENT_ACCOUNT_NAME=
MANUAL_PAYMENT_INSTRUCTIONS=
MANUAL_PAYMENT_HOLD_MINUTES=720
MANUAL_PAYMENT_REVIEW_SECRET=

# SMS payment confirmation
SMS_PROVIDER=smsapi
SMS_API_KEY=
SMS_SENDER=
SMS_API_BASE_URL=https://api.smsapi.com

# Legacy SMS webhook fallback
SMS_NOTIFICATION_WEBHOOK_URL=
SMS_NOTIFICATION_WEBHOOK_TOKEN=

# Supabase live mode
NEXT_PUBLIC_SUPABASE_URL=
# Must be a real service-role key (sb_secret_... or legacy JWT with role=service_role), never sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=

# PayU
PAYU_MODE=auto
PAYU_ENVIRONMENT=sandbox
PAYU_CLIENT_ID=
PAYU_CLIENT_SECRET=
PAYU_POS_ID=
PAYU_SECOND_KEY=

# Legacy Stripe mode
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
